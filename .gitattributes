# Normalize line endings so Windows .bat files work on every clone regardless
# of the dev's OS, and bash scripts keep LF.

*                 text=auto eol=lf

# Windows-native scripts must be CRLF or cmd.exe may misbehave on older Win 10.
*.bat             text eol=crlf
*.cmd             text eol=crlf
*.ps1             text eol=crlf

# Unix-native scripts stay LF.
*.sh              text eol=lf
*.command         text eol=lf

# Binaries
*.png             binary
*.jpg             binary
*.jpeg            binary
*.gif             binary
*.ico             binary
*.icns            binary
*.pdf             binary
*.db              binary
*.sqlite          binary
*.sqlite3         binary
*.zip             binary
*.exe             binary
